# Claude Code
# Track agents, skills, commands, hooks, settings.json, memory, and task contracts
# (shared team config + tribal knowledge). Ignore transient agent outputs and
# per-developer overrides.
.claude/plans/
.claude/reports/
.claude/settings.local.json
.claude/.local/

# Superpowers docs
docs/superpowers/

# Fastlane
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots/**/*.png
**/fastlane/test_output
**/fastlane/README.md

# Test fixtures — Hive boxes from path_provider mock (see test/helpers/fake_path_provider_platform.dart)
.docs/

# Per-developer git worktrees (git-worktree skill recommends placing them OUTSIDE project root)
.worktrees/
.vscode/templates

# Claude Code config — local only, never pushed
.claude/

# Local tooling — agent definitions + skills lockfile (per-developer, never pushed)
.agents/
skills-lock.json

# Boilerplate: keep real Firebase configs local-only (run flutterfire configure per project)
**/google-services.json
**/GoogleService-Info.plist
# flutterfire writes this with real per-project API keys; the app uses the
# env-based options under lib/core/.../firebase/ instead, so keep it untracked.
/lib/firebase_options.dart
# flutterfire project map (per-developer; records the local Firebase project)
/firebase.json
